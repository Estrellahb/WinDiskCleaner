<UserControl x:Class="WinDiskCleaner.App.Views.DuplicateFilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="重复文件检测" FontSize="22" FontWeight="Bold"/>
            <TextBlock Text="按大小、局部哈希和 SHA256 检测重复文件。默认建议保留每组最新文件。" Foreground="#666" Margin="0,6,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ScanPathsBox" Height="32" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
            <Button Grid.Column="1" Content="浏览" Width="80" Height="32" Margin="0,0,8,0" Click="BrowseBtn_Click"/>
            <Button Grid.Column="2" x:Name="StartScanBtn" Content="开始扫描" Width="100" Height="32" Margin="0,0,8,0" Background="#0078D4" Foreground="White" Click="StartScanBtn_Click"/>
            <Button Grid.Column="3" x:Name="CancelScanBtn" Content="取消扫描" Width="100" Height="32" IsEnabled="False" Click="CancelScanBtn_Click"/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <ProgressBar x:Name="ScanProgressBar" Height="10" Minimum="0" Maximum="100"/>
                <TextBlock x:Name="StatusText" Text="等待扫描" Margin="0,6,0,0" Foreground="#666"/>
                <TextBlock x:Name="WastedSpaceText" Text="可释放空间：0 B" FontWeight="Bold" Margin="0,6,0,0"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="GroupsList" ItemsSource="{Binding DuplicateGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander Margin="0,0,0,10" IsExpanded="True">
                                <Expander.Header>
                                    <StackPanel>
                                        <TextBlock FontWeight="Bold" Text="{Binding Hash}"/>
                                        <TextBlock Foreground="#666" Text="{Binding SummaryText}"/>
                                    </StackPanel>
                                </Expander.Header>
                                <ItemsControl ItemsSource="{Binding Files}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox IsChecked="{Binding Selected, Mode=TwoWay}" IsEnabled="{Binding CanSelect}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Path}" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding DetailText}" Foreground="#666"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding RecommendedText}" Foreground="#107C10" FontWeight="Bold" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="全选建议" Width="100" Height="32" Margin="0,0,8,0" Click="SelectRecommendedBtn_Click"/>
            <Button Content="反选" Width="80" Height="32" Margin="0,0,8,0" Click="InvertSelectionBtn_Click"/>
            <Button Content="删除选中" Width="100" Height="32" Margin="0,0,8,0" Background="#D83B01" Foreground="White" Click="DeleteSelectedBtn_Click"/>
            <Button Content="导出报告" Width="100" Height="32" Click="ExportReportBtn_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
