<UserControl x:Class="WinDiskCleaner.App.Views.SpaceMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:WinDiskCleaner.App.Controls">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 盘符选择 -->
        <StackPanel Orientation="Horizontal" Margin="10">
            <TextBlock Text="选择盘符：" VerticalAlignment="Center" FontSize="14"/>
            <ComboBox x:Name="DriveCombo" Width="120" Margin="10,0" SelectedIndex="0"/>
            <Button x:Name="ScanBtn" Content="开始扫描" Width="100" Height="30"
                    Background="#0078D4" Foreground="White" Click="ScanBtn_Click"/>
            <Button x:Name="CancelBtn" Content="取消" Width="80" Height="30" Margin="10,0" IsEnabled="False" Click="CancelBtn_Click"/>
            <ProgressBar x:Name="ScanProgress" Width="200" Height="20" Margin="10,0"/>
        </StackPanel>

        <!-- Treemap -->
        <controls:TreemapControl x:Name="Treemap" Grid.Row="1" Margin="10"/>
    </Grid>
</UserControl>
