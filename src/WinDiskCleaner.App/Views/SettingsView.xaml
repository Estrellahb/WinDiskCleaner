<UserControl x:Class="WinDiskCleaner.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="AI 模型配置" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
            <TextBlock Text="API BaseURL" FontSize="13" Margin="0,0,0,4"/>
            <TextBox x:Name="BaseUrlBox" Text="https://api.openai.com/v1" Height="30" Margin="0,0,0,12"/>
            <TextBlock Text="API Key" FontSize="13" Margin="0,0,0,4"/>
            <PasswordBox x:Name="ApiKeyBox" Height="30" Margin="0,0,0,12"/>
            <TextBlock Text="模型名称" FontSize="13" Margin="0,0,0,4"/>
            <TextBox x:Name="ModelBox" Text="gpt-4o" Height="30" Margin="0,0,0,20"/>
            <StackPanel Orientation="Horizontal">
                <Button Content="测试连接" Width="100" Height="32"
                        Background="#0078D4" Foreground="White" Click="TestBtn_Click"/>
                <Button Content="保存配置" Width="100" Height="32" Margin="10,0,0,0" Click="SaveBtn_Click"/>
            </StackPanel>
            <TextBlock x:Name="StatusText" Margin="0,10,0,0" Foreground="#666"/>
        </StackPanel>
    </Grid>
</UserControl>
